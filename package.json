{
  "name": "orbital-clash",
  "version": "0.1.0",
  "private": true,
  "description": "Top-down multiplayer space arena game with gravity mechanics",
  "scripts": {
    "dev:client": "vite",
    "dev:server": "wrangler dev",
    "build:client": "vite build",
    "build": "vite build",
    "db:migrate": "wrangler d1 execute orbital-clash-db --remote --file=src/server/schema.sql",
    "deploy": "vite build && wrangler deploy && npm run db:migrate",
    "deploy:smoke": "node scripts/smoke-test.js",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "@playwright/test": "^1.58.2",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^4.0.18",
    "wrangler": "^3.109.0"
  }
}
